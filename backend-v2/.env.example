HOST=0.0.0.0
PORT=3211
MOMENTPIC_DB_PATH=/app/data/momentpic-v2.sqlite
MOMENTPIC_SEED_DEMO=false

# Set strong values in your real deployment. Do not commit .env.
MOMENTPIC_ADMIN_USERNAME=admin
MOMENTPIC_ADMIN_PASSWORD=change-me-admin-password
MOMENTPIC_AUTH_SECRET=change-me-random-auth-secret

# Optional: map legacy media paths stored in an imported DB to paths readable by this runtime.
# Example:
# MOMENTPIC_PATH_PREFIX_MAP=[{"from":"/legacy/media/root/","to":"/runtime/media/root/"}]
MOMENTPIC_PATH_PREFIX_MAP=[]

MOMENTPIC_LIBRARY_ALLOWED_ROOTS=/app/media
MOMENTPIC_THUMBNAIL_CACHE_DIR=/app/data/thumbnails
MOMENTPIC_THUMBNAIL_MAX_SIZE=640
MOMENTPIC_ARCHIVE_ENTRY_MAX_BYTES=67108864
